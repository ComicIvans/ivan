# ─────────────────────────────────────────────────────────────
# BUILD-TIME (baked into the Docker image by deploy.sh build args)
# ─────────────────────────────────────────────────────────────

# Application
SITE_URL=https://tusitio.example.com

# Analytics
NUXT_UMAMI_HOST=https://analytics.example.com
NUXT_UMAMI_ID=00000000-0000-0000-0000-000000000000

# ─────────────────────────────────────────────────────────────
# RUNTIME (provided to the running container via docker-compose env_file)
# ─────────────────────────────────────────────────────────────

# Mail
# NUXT_-prefixed because Nuxt only overrides runtimeConfig from env vars with
# that prefix at runtime. Plain SMTP_* names are silently ignored in production.
NUXT_SMTP_HOST=smtp.example.com
NUXT_SMTP_PORT=465
NUXT_SMTP_SECURE=true
NUXT_SMTP_USER=usuario_ejemplo
NUXT_SMTP_PASS=contraseña_ejemplo
NUXT_SMTP_FROM_EMAIL=remitente@example.com
NUXT_SMTP_TO_EMAIL=destinatario@example.com

# Optional: directory for the file-based contact rate limiter.
# NOTE: read at build time (baked into the image), NOT a runtime override.
# Set it as a build arg if you need to change it; otherwise it defaults to
# /data/ratelimit (persisted Docker volume).
# RATE_LIMIT_DIR=/data/ratelimit

# Force search-engine indexability at runtime regardless of build NODE_ENV.
# docker-compose.yml already sets this to true for production; set to "false"
# for staging/preview deployments that must stay out of search results.
# NUXT_SITE_INDEXABLE=true

# ─────────────────────────────────────────────────────────────
# DEPLOYMENT (used by deploy.sh on the operator's machine)
# ─────────────────────────────────────────────────────────────
VPS_HOST=usuario@vps.example.com
REMOTE_DIR=/ruta/remota/ejemplo

# GHCR credentials for pushing (local) and pulling (VPS) a private image.
# Needed because ghcr.io/comicivans/ivan is private — without them the VPS
# `docker compose pull` fails with "denied". Use a GitHub PAT with read:packages
# (write:packages too if pushing from here). Alternatively run `docker login
# ghcr.io` once on the VPS, or make the GHCR package public.
GHCR_USERNAME=tu-usuario-github
GHCR_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
